import { HudToolbarButtonData } from "types.slint";

component HudButton inherits Rectangle {
    in property <image> icon-source;
    in property <string> text: "";
    in property <string> tooltip-text;
    in property <bool> active: false;
    out property <bool> hovered: touch.has-hover;
    callback clicked();

    width: 38px;
    height: 38px;
    border-radius: 0px;
    background: touch.has-hover ? #ffffff22 : active ? #ffffff15 : transparent;

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    if root.text == "": Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 18px;
        height: 18px;
        source: root.icon-source;
        image-fit: contain;
        colorize: root.active ? white : #cccccc;
    }

    if root.text != "": Text {
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: root.active ? white : #cccccc;
        font-size: 18px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component HudSeparator inherits Rectangle {
    width: 1px;
    height: 38px;
    background: #ffffff20;
}

export component HudToolbar inherits Rectangle {
    in property <float> zoom-level: 1.0;
    in property <bool> dropdown-open: false;
    in property <bool> has-adjustments: false;
    in property <[HudToolbarButtonData]> plugin-buttons: [];

    callback fit-to-view();
    callback zoom-in();
    callback zoom-out();
    callback toggle-dropdown();
    callback zoom-input(float);
    callback plugin-button-clicked(string, string);
    callback dismiss-plugin-menu();

    property <string> zoom-text: zoom-level >= 1.0 ? Math.round(zoom-level * 100) + "%" : Math.round(zoom-level * 1000) / 10 + "%";
    property <string> zoom-input-text: zoom-level >= 1.0 ? "" + Math.round(zoom-level * 100) : "" + (Math.round(zoom-level * 1000) / 10);
    property <bool> editing-zoom: false;
    property <bool> cancel-zoom-edit: false;
    in-out property <bool> plugin-menu-open: false;
    property <string> plugin-menu-plugin-id: "";
    property <string> plugin-menu-button-id: "";
    property <length> plugin-menu-x: 0px;
    property <length> plugin-menu-y: root.height + 6px;
    property <string> eovae-visualization-button-id: "visualization_mode";
    property <[string]> eovae-visualization-labels: ["Original", "Reconstruction", "Difference", "Error Map"];
    property <[string]> eovae-visualization-actions: [
        "set_visualization_original",
        "set_visualization_reconstruction",
        "set_visualization_difference",
        "set_visualization_error_map",
    ];

    property <string> active-tooltip:
        fit-btn.hovered ? fit-btn.tooltip-text : zoom-in-btn.hovered ? zoom-in-btn.tooltip-text : zoom-out-btn.hovered ? zoom-out-btn.tooltip-text : adjust-btn.hovered ? adjust-btn.tooltip-text : "";
    property <length> tooltip-center-x:
        fit-btn.hovered ? fit-btn.x + fit-btn.width / 2 : zoom-in-btn.hovered ? zoom-in-btn.x + zoom-in-btn.width / 2 : zoom-out-btn.hovered ? zoom-out-btn.x + zoom-out-btn.width / 2 : adjust-btn.hovered ? adjust-btn.x + adjust-btn.width / 2 : 0px;

    width: bar.preferred-width;
    height: 38px;
    background: transparent;

    dismiss-plugin-menu => {
        root.plugin-menu-open = false;
    }

    // Clipped bar container for rounded corners
    bar := Rectangle {
        width: 100%;
        height: 100%;
        background: #101419cc;
        border-radius: 8px;
        border-width: 0px;
        border-color: transparent;
        clip: true;

        HorizontalLayout {
            padding: 0px;
            spacing: 0px;

            // Zoom label / text input
            Rectangle {
                width: 72px;
                height: 38px;
                border-radius: 0px;
                background: zoom-touch.has-hover || root.editing-zoom ? #ffffff15 : transparent;

                Text {
                    visible: !root.editing-zoom;
                    text: root.zoom-text;
                    color: #e0e0e0;
                    font-size: 15px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Rectangle {
                    visible: root.editing-zoom;
                    x: 4px;
                    y: (parent.height - self.height) / 2;
                    width: parent.width - 8px;
                    height: 26px;
                    background: root.editing-zoom ? #1a1f28 : transparent;
                    border-radius: 4px;
                    border-width: root.editing-zoom ? 1px : 0px;
                    border-color: #4da3d9;

                    zoom-text-input := TextInput {
                        x: 4px;
                        width: parent.width - 8px;
                        color: white;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        text: root.zoom-input-text;
                        input-type: InputType.decimal;

                        accepted => {
                            root.cancel-zoom-edit = false;
                            root.editing-zoom = false;
                            root.zoom-input(self.text.to-float() / 100.0);
                        }

                        changed has-focus => {
                            if !self.has-focus && root.editing-zoom {
                                if root.cancel-zoom-edit {
                                    root.cancel-zoom-edit = false;
                                    root.editing-zoom = false;
                                    self.text = root.zoom-input-text;
                                } else {
                                    root.editing-zoom = false;
                                    root.zoom-input(self.text.to-float() / 100.0);
                                }
                            }
                        }

                        key-pressed(e) => {
                            if e.text == Key.Escape {
                                root.cancel-zoom-edit = true;
                                root.editing-zoom = false;
                                self.text = root.zoom-input-text;
                                accept
                            }
                            reject
                        }
                    }
                }

                zoom-touch := TouchArea {
                    enabled: !root.editing-zoom;
                    clicked => {
                        root.cancel-zoom-edit = false;
                        zoom-text-input.text = root.zoom-input-text;
                        root.editing-zoom = true;
                        zoom-text-input.focus();
                        zoom-text-input.select-all();
                    }
                }
            }

            // Separator
            HudSeparator {}

            fit-btn := HudButton {
                icon-source: @image-url("icons/fit-view.svg");
                tooltip-text: "Fit to view";
                clicked => {
                    root.fit-to-view();
                }
            }

            zoom-in-btn := HudButton {
                icon-source: @image-url("icons/zoom-in.svg");
                tooltip-text: "Zoom in";
                clicked => {
                    root.zoom-in();
                }
            }

            zoom-out-btn := HudButton {
                icon-source: @image-url("icons/zoom-out.svg");
                tooltip-text: "Zoom out";
                clicked => {
                    root.zoom-out();
                }
            }

            for btn[idx] in root.plugin-buttons: HorizontalLayout {
                spacing: 0px;

                if idx == 0 || root.plugin-buttons[idx - 1].plugin-id != btn.plugin-id: HudSeparator {}

                HudButton {
                    icon-source: btn.icon;
                    tooltip-text: btn.tooltip;
                    active: btn.active || (root.plugin-menu-open && root.plugin-menu-plugin-id == btn.plugin-id && root.plugin-menu-button-id == btn.button-id);
                    clicked => {
                        if btn.button-id == root.eovae-visualization-button-id {
                            if root.plugin-menu-open && root.plugin-menu-plugin-id == btn.plugin-id && root.plugin-menu-button-id == btn.button-id {
                                root.plugin-menu-open = false;
                            } else {
                                root.plugin-menu-plugin-id = btn.plugin-id;
                                root.plugin-menu-button-id = btn.button-id;
                                root.plugin-menu-x = self.absolute-position.x - root.absolute-position.x;
                                root.plugin-menu-open = true;
                            }
                        } else {
                            root.plugin-menu-open = false;
                            root.plugin-button-clicked(btn.plugin-id, btn.action-id);
                        }
                    }
                }
            }

            if root.plugin-buttons.length > 0: HudSeparator {}

            adjust-btn := HudButton {
                icon-source: @image-url("icons/settings.svg");
                tooltip-text: "Adjustments";
                active: root.dropdown-open || root.has-adjustments;
                clicked => {
                    root.toggle-dropdown();
                }
            }
        }
    }

    // Tooltip rendered outside the clipped bar
    if active-tooltip != "": Rectangle {
        x: root.tooltip-center-x - self.width / 2;
        y: root.height + 6px;
        width: hud-tt-text.preferred-width + 12px;
        height: hud-tt-text.preferred-height + 6px;
        background: #111111ee;
        border-radius: 4px;
        border-width: 1px;
        border-color: #ffffff30;

        hud-tt-text := Text {
            x: 6px;
            y: 3px;
            text: root.active-tooltip;
            color: white;
            font-size: 11px;
        }
    }

    if root.plugin-menu-open && root.plugin-menu-button-id == root.eovae-visualization-button-id: Rectangle {
        x: root.plugin-menu-x;
        y: root.plugin-menu-y;
        width: 136px;
        height: root.eovae-visualization-labels.length * 30px + (root.eovae-visualization-labels.length - 1) * 2px + 12px;
        background: #11151cee;
        border-radius: 8px;
        border-width: 1px;
        border-color: #ffffff24;
        clip: true;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding: 6px;
            spacing: 2px;

            for label[idx] in root.eovae-visualization-labels: Rectangle {
                height: 30px;
                border-radius: 4px;
                background: item-touch.has-hover ? #ffffff16 : transparent;

                Text {
                    x: 10px;
                    y: (parent.height - self.height) / 2;
                    text: label;
                    color: white;
                    font-size: 12px;
                }

                item-touch := TouchArea {
                    clicked => {
                        root.plugin-menu-open = false;
                        root.plugin-button-clicked(root.plugin-menu-plugin-id, root.eovae-visualization-actions[idx]);
                    }
                }
            }
        }
    }
}
