import { MeasurementUnit } from "types.slint";

export component ScaleBar inherits Rectangle {
    in property <float> zoom: 1.0;
    in property <float> mpp-x: 0.0;
    in property <float> mpp-y: 0.0;
    in property <MeasurementUnit> unit: MeasurementUnit.um;

    property <bool> has-calibration: mpp-x > 0.0 && mpp-y > 0.0;
    property <float> avg-mpp: (mpp-x + mpp-y) / 2.0;
    // pixels per um at current zoom
    property <float> px-per-um: has-calibration ? zoom / avg-mpp : 0.0;
    // target bar width in pixels (aim for 80-140px)
    property <float> target-bar-px: 110.0;
    // target distance in um
    property <float> target-um: has-calibration && px-per-um > 0.0 ? target-bar-px / px-per-um : 0.0;

    // Pick a nice round distance and compute bar width from it.
    // We use a chain of conditionals to select the nearest "nice" value.
    property <float> nice-um:
        target-um <= 0.0 ? 0.0 : target-um < 0.15 ? 0.1 : target-um < 0.35 ? 0.25 : target-um < 0.75 ? 0.5 : target-um < 1.5 ? 1.0 : target-um < 3.5 ? 2.5 : target-um < 7.5 ? 5.0 : target-um < 15.0 ? 10.0 : target-um < 35.0 ? 25.0 : target-um < 75.0 ? 50.0 : target-um < 150.0 ? 100.0 : target-um < 350.0 ? 250.0 : target-um < 750.0 ? 500.0 : target-um < 1500.0 ? 1000.0 : target-um < 3500.0 ? 2500.0 : target-um < 7500.0 ? 5000.0 : target-um < 15000.0 ? 10000.0 : target-um < 35000.0 ? 25000.0 : target-um < 75000.0 ? 50000.0 : target-um < 150000.0 ? 100000.0 : target-um < 350000.0 ? 250000.0 : 500000.0;

    property <float> bar-width-px: has-calibration ? nice-um * px-per-um : 0.0;

    // Label: convert to appropriate unit
    property <string> label-text:
        !has-calibration ? "" : unit == MeasurementUnit.inches ? (nice-um >= 25400 ? Math.round(nice-um / 254) / 100 + " in" : Math.round(nice-um / 25.4 * 1000) / 1000 + " in") : unit == MeasurementUnit.mm ? Math.round(nice-um / 10) / 100 + " mm" : nice-um >= 1000 ? Math.round(nice-um / 10) / 100 + " mm" : Math.round(nice-um) + " µm";

    width: max(60px, bar-width-px * 1px + 24px);
    height: 32px;
    background: transparent;
    visible: has-calibration && bar-width-px > 5.0;

    Rectangle {
        x: (parent.width - bar-width-px * 1px) / 2 - 1px;
        y: parent.height - 12px - 1px;
        width: bar-width-px * 1px + 2px;
        height: 3px + 2px;
        background: black;
        border-radius: 2px;
    }

    Rectangle {
        x: (parent.width - bar-width-px * 1px) / 2;
        y: parent.height - 12px;
        width: bar-width-px * 1px;
        height: 3px;
        background: white;
        border-radius: 1px;

        // Left tick outline
        Rectangle {
            x: -1px;
            y: -4px - 1px;
            width: 2px + 2px;
            height: 10px + 2px;
            background: black;
        }

        // Left tick
        Rectangle {
            x: 0px;
            y: -4px;
            width: 2px;
            height: 10px;
            background: white;
        }

        // Right tick outline
        Rectangle {
            x: parent.width - 2px - 1px;
            y: -4px - 1px;
            width: 2px + 2px;
            height: 10px + 2px;
            background: black;
        }

        // Right tick
        Rectangle {
            x: parent.width - 2px;
            y: -4px;
            width: 2px;
            height: 10px;
            background: white;
        }
    }

    // Text stroke (black outline via offset copies)
    Text {
        x: -1px;
        y: -1px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: 0px;
        y: -1px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: 1px;
        y: -1px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: -1px;
        y: 0px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: 1px;
        y: 0px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: -1px;
        y: 1px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: 0px;
        y: 1px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: 1px;
        y: 1px;
        width: 100%;
        text: root.label-text;
        color: black;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }

    Text {
        x: 0px;
        y: 0px;
        width: 100%;
        text: root.label-text;
        color: white;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }
}
