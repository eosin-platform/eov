import { Theme } from "theme.slint";
import { SvgIconButton } from "tab-controls.slint";
import { SeriesItemData } from "types.slint";

component SeriesCard inherits Rectangle {
    in property <SeriesItemData> item;
    in property <bool> selected: false;
    out property <bool> hovered: touch.has-hover;
    callback activated(string);
    callback context-menu(string, length, length);
    callback horizontal-scroll(length);
    callback show-tooltip(string, length, length);
    callback clear-tooltip(string);

    width: 148px;
    height: 150px;
    border-radius: 8px;
    background: touch.has-hover ? Theme.surface-hover : Theme.surface;

    touch := TouchArea {
        clicked => {
            root.activated(root.item.path);
        }

        changed has-hover => {
            if self.has-hover {
                root.show-tooltip(
                    root.item.name,
                    root.absolute-position.x + root.width / 2,
                    root.absolute-position.y - 8px,
                );
            } else {
                root.clear-tooltip(root.item.name);
            }
        }

        scroll-event(e) => {
            root.horizontal-scroll(e.delta-y);
            accept
        }

        pointer-event(e) => {
            if !root.item.is-directory
                && e.kind == PointerEventKind.down
                && e.button == PointerEventButton.right
            {
                root.context-menu(
                    root.item.path,
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y,
                );
            }
        }
    }

    VerticalLayout {
        padding: 8px;
        spacing: 4px;

        HorizontalLayout {
            height: 16px;
            padding-left: 4px;
            padding-right: 4px;
            spacing: 6px;
            alignment: stretch;

            if item.series_label != "": Text {
                text: item.series_label;
                color: Theme.text-secondary;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
            }

            Text {
                text: item.name;
                color: Theme.text-primary;
                font-size: 11px;
                font-weight: 500;
                horizontal-alignment: right;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            height: 112px;
            border-radius: 6px;
            background: #111318;
            border-width: 1px;
            border-color: selected ? Theme.accent : Theme.border-subtle;
            clip: true;

            if item.is-directory: Image {
                x: parent.width / 2 - self.width / 2;
                y: parent.height / 2 - self.height / 2;
                width: 34px;
                height: 34px;
                source: @image-url("icons/open-file.svg");
                image-fit: contain;
                opacity: 0.92;
            }

            if !item.is-directory && !item.is-loading && item.has-thumbnail: Image {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                source: item.thumbnail;
                image-fit: contain;
            }

            if !item.is-directory && item.objective_label != "": Rectangle {
                x: 8px;
                y: 8px;
                height: 20px;
                width: objective-text.width + 10px;
                border-radius: 4px;
                background: #0f141bcc;

                objective-text := Text {
                    x: 5px;
                    y: 3px;
                    text: item.objective_label;
                    color: white;
                    font-size: 11px;
                    font-weight: 700;
                }
            }

            if !item.is-directory && item.stain_label != "": Rectangle {
                y: parent.height - self.height - 8px;
                height: 20px;
                width: stain-text.width + 10px;
                x: parent.width - self.width - 8px;
                border-radius: 4px;
                background: #0f141bcc;

                stain-text := Text {
                    x: 5px;
                    y: 3px;
                    text: item.stain_label;
                    color: white;
                    font-size: 11px;
                    font-weight: 600;
                }
            }

            if !item.is-directory && item.is-loading: Rectangle {
                x: 10px;
                y: parent.height / 2 - self.height / 2;
                width: parent.width - 20px;
                height: 28px;
                border-radius: 14px;
                background: #ffffff10;
                opacity: 0.55;

                Text {
                    text: "Loading thumbnail";
                    color: Theme.text-secondary;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if !item.is-directory && !item.is-loading && !item.has-thumbnail: Text {
                text: "No Preview";
                color: Theme.text-secondary;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

    }
}

export component SeriesBar inherits Rectangle {
    in property <[SeriesItemData]> items: [];
    in property <string> selected-path: "";
    in property <bool> can-go-back: false;
    in property <bool> can-go-forward: false;
    in property <bool> can-go-up: false;
    callback open-folder-requested();
    callback open-folder-menu-requested(length, length);
    callback go-back();
    callback go-forward();
    callback go-up();
    callback hide-requested();
    callback item-activated(string);
    callback item-context-menu(string, length, length);

    property <string> active-tooltip: "";
    property <length> tooltip-x: 0px;
    property <length> tooltip-y: 0px;
    property <length> scroll-x: 0px;

    function show-tooltip(text: string, center-x: length, top-y: length) {
        root.active-tooltip = text;
        root.tooltip-x = center-x - root.absolute-position.x;
        root.tooltip-y = top-y - root.absolute-position.y;
    }

    function clear-tooltip(text: string) {
        if root.active-tooltip == text {
            root.active-tooltip = "";
        }
    }

    clip: true;
    background: Theme.surface;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 30px;
        background: Theme.toolbar-bg;

        Rectangle {
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: Theme.border-subtle;
        }

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            alignment: stretch;
            spacing: 4px;

            back-button := SvgIconButton {
                icon-source: @image-url("icons/back.svg");
                tooltip-text: "Back";
                enabled: root.can-go-back;
                clicked => {
                    root.go-back();
                }
                changed hovered => {
                    if self.hovered {
                        root.show-tooltip(self.tooltip-text, self.absolute-position.x + self.width / 2, self.absolute-position.y - 8px);
                    } else {
                        root.clear-tooltip(self.tooltip-text);
                    }
                }
            }

            forward-button := SvgIconButton {
                icon-source: @image-url("icons/forward.svg");
                tooltip-text: "Forward";
                enabled: root.can-go-forward;
                clicked => {
                    root.go-forward();
                }
                changed hovered => {
                    if self.hovered {
                        root.show-tooltip(self.tooltip-text, self.absolute-position.x + self.width / 2, self.absolute-position.y - 8px);
                    } else {
                        root.clear-tooltip(self.tooltip-text);
                    }
                }
            }

            up-button := SvgIconButton {
                icon-source: @image-url("icons/up.svg");
                tooltip-text: "Up";
                enabled: root.can-go-up;
                clicked => {
                    root.go-up();
                }
                changed hovered => {
                    if self.hovered {
                        root.show-tooltip(self.tooltip-text, self.absolute-position.x + self.width / 2, self.absolute-position.y - 8px);
                    } else {
                        root.clear-tooltip(self.tooltip-text);
                    }
                }
            }

            Rectangle {
                width: 1px;
                height: 18px;
                y: (parent.height - self.height) / 2;
                background: Theme.border;
            }

            open-folder-button := SvgIconButton {
                icon-source: @image-url("icons/open-file.svg");
                tooltip-text: "Open Folder";
                clicked => {
                    root.open-folder-requested();
                }
                secondary-clicked(x, y) => {
                    root.open-folder-menu-requested(x, y);
                }
                changed hovered => {
                    if self.hovered {
                        root.show-tooltip(self.tooltip-text, self.absolute-position.x + self.width / 2, self.absolute-position.y - 8px);
                    } else {
                        root.clear-tooltip(self.tooltip-text);
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }

            hide-button := SvgIconButton {
                icon-source: @image-url("icons/hide-series.svg");
                tooltip-text: "Hide Series Bar";
                clicked => {
                    root.hide-requested();
                }
                changed hovered => {
                    if self.hovered {
                        root.show-tooltip(self.tooltip-text, self.absolute-position.x + self.width / 2, self.absolute-position.y - 8px);
                    } else {
                        root.clear-tooltip(self.tooltip-text);
                    }
                }
            }
        }
    }

    if root.items.length == 0: Rectangle {
        x: (parent.width - self.width) / 2;
        y: 42px + (parent.height - 42px - self.height) / 2;
        width: 280px;
        height: 92px;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.border;
        background: #111318;

        VerticalLayout {
            alignment: center;
            spacing: 8px;

            Text {
                text: "Empty folder";
                color: Theme.text-primary;
                font-size: 15px;
                font-weight: 600;
                horizontal-alignment: center;
            }

            Text {
                text: "No folders or supported WSI files are visible here.";
                color: Theme.text-secondary;
                font-size: 12px;
                horizontal-alignment: center;
            }
        }
    }

    if root.items.length > 0: Rectangle {
        x: 0px;
        y: 30px;
        width: parent.width;
        height: parent.height - 30px;
        clip: true;

        TouchArea {
            width: parent.width;
            height: parent.height;
            scroll-event(e) => {
                root.scroll-x = clamp(
                    root.scroll-x - e.delta-y,
                    0px,
                    max(0px, series-layout.preferred-width + 24px - parent.width)
                );
                accept
            }
        }

        series-layout := HorizontalLayout {
            x: -root.scroll-x;
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 10px;

            for item[i] in root.items: SeriesCard {
                item: item;
                selected: root.selected-path == item.path;
                horizontal-scroll(delta) => {
                    root.scroll-x = clamp(
                        root.scroll-x - delta,
                        0px,
                        max(0px, series-layout.preferred-width + 24px - root.width)
                    );
                }
                activated(path) => {
                    if item.is-directory {
                        root.scroll-x = 0px;
                    }
                    root.item-activated(path);
                }
                context-menu(path, x, y) => {
                    root.item-context-menu(path, x, y);
                }
                show-tooltip(text, center-x, top-y) => {
                    root.show-tooltip(text, center-x, top-y);
                }
                clear-tooltip(text) => {
                    root.clear-tooltip(text);
                }
            }
        }
    }

    if root.active-tooltip != "": Rectangle {
        x: max(8px, min(root.width - self.width - 8px, root.tooltip-x - self.width / 2));
        y: max(8px, root.tooltip-y - self.height);
        width: tooltip-text.preferred-width + 16px;
        height: tooltip-text.preferred-height + 12px;
        background: #101216f2;
        border-radius: 6px;
        border-width: 1px;
        border-color: Theme.border;

        tooltip-text := Text {
            x: 8px;
            y: 6px;
            width: parent.width - 16px;
            text: root.active-tooltip;
            color: white;
            font-size: 11px;
            wrap: word-wrap;
        }
    }
}
