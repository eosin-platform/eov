import { Theme } from "theme.slint";
import {
    FilteringMode,
    PluginButtonData,
    RenderMode,
    ToolType,
} from "types.slint";
import {
    MetadataToolButton,
    MinimapToolButton,
    OpenFileToolButton,
    RoiToolButton,
    SvgToolButton,
    ToolButton,
} from "tab-controls.slint";

export component WindowToolbar inherits Rectangle {
    in property <ToolType> current-tool: ToolType.navigate;
    in property <RenderMode> render-mode: RenderMode.cpu;
    in property <bool> gpu-rendering-available: false;
    in property <bool> show-minimap: true;
    in property <bool> show-metadata: false;
    in property <bool> show-scale-bar: true;
    in property <bool> use-native-window-controls: false;
    in property <bool> plugin-undo-redo-visible: false;
    in property <bool> plugin-undo-enabled: false;
    in property <bool> plugin-redo-enabled: false;
    in property <string> plugin-undo-redo-plugin-id: "";
    in property <FilteringMode> filtering-mode: FilteringMode.trilinear;
    in property <int> filtering-mode-index: filtering-mode == FilteringMode.bilinear ? 0 : filtering-mode == FilteringMode.trilinear ? 1 : 2;
    in-out property <bool> filter-popup-visible: false;
    in property <[PluginButtonData]> plugin-buttons: [];
    property <string> plugin-hovered-tooltip-text: "";
    property <length> plugin-hovered-tooltip-center-x: 0px;
    property <length> plugin-hovered-tooltip-top-y: 0px;
    property <string> primary-shortcut-label: root.use-native-window-controls ? "⌘" : "Ctrl";
    property <string> undo-tooltip-text: "Undo (" + root.primary-shortcut-label + "+Z)";
    property <string> redo-tooltip-text:
        "Redo ("
        + root.primary-shortcut-label
        + "+Y or "
        + (root.use-native-window-controls ? "Shift+⌘+Z" : "Ctrl+Shift+Z")
        + ")";

    callback open-file-requested();
    callback open-recent-menu-requested(length, length);
    callback toggle-minimap-requested();
    callback toggle-metadata-requested();
    callback toggle-scale-bar-requested();
    callback tool-selected(ToolType);
    callback render-backend-selected(RenderMode);
    callback filtering-mode-selected(FilteringMode);
    callback dataset-export-requested();
    callback plugin-button-clicked(string, string);
    callback plugin-undo-requested(string);
    callback plugin-redo-requested(string);
    callback window-minimize();
    callback window-maximize();
    callback window-close();

    out property <float> drag-area-x: drag-area.x / 1px;
    out property <float> drag-area-width: drag-area.width / 1px;
    out property <length> filter-combo-abs-x: filter-combo-area.absolute-position.x;
    out property <length> filter-combo-abs-y: filter-combo-area.absolute-position.y + filter-combo-area.height + 2px;
    out property <length> filter-combo-width: filter-combo-area.width;
    out property <bool> hovered-tooltip-visible: hovered-tooltip-text != "";
    out property <string> hovered-tooltip-text:
        open-button.hovered ? open-button.tooltip-text : plugin-undo-button.hovered ? plugin-undo-button.tooltip-text : plugin-redo-button.hovered ? plugin-redo-button.tooltip-text : minimap-button.hovered ? minimap-button.tooltip-text : navigate-button.hovered ? navigate-button.tooltip-text : roi-button.hovered ? roi-button.tooltip-text : measure-button.hovered ? measure-button.tooltip-text : cpu-button.hovered ? cpu-button.tooltip-text : gpu-button.hovered ? gpu-button.tooltip-text : metadata-button.hovered ? metadata-button.tooltip-text : scale-bar-button.hovered ? scale-bar-button.tooltip-text : dataset-export-button.hovered ? dataset-export-button.tooltip-text : root.plugin-hovered-tooltip-text != "" ? root.plugin-hovered-tooltip-text : !root.use-native-window-controls && minimize-touch.has-hover ? "Minimize window" : !root.use-native-window-controls && maximize-touch.has-hover ? "Maximize window" : !root.use-native-window-controls && close-win-touch.has-hover ? "Close window" : "";
    out property <length> hovered-tooltip-center-x:
        open-button.hovered ? open-button.absolute-position.x + open-button.width / 2 : plugin-undo-button.hovered ? plugin-undo-button.absolute-position.x + plugin-undo-button.width / 2 : plugin-redo-button.hovered ? plugin-redo-button.absolute-position.x + plugin-redo-button.width / 2 : minimap-button.hovered ? minimap-button.absolute-position.x + minimap-button.width / 2 : navigate-button.hovered ? navigate-button.absolute-position.x + navigate-button.width / 2 : roi-button.hovered ? roi-button.absolute-position.x + roi-button.width / 2 : measure-button.hovered ? measure-button.absolute-position.x + measure-button.width / 2 : cpu-button.hovered ? cpu-button.absolute-position.x + cpu-button.width / 2 : gpu-button.hovered ? gpu-button.absolute-position.x + gpu-button.width / 2 : metadata-button.hovered ? metadata-button.absolute-position.x + metadata-button.width / 2 : scale-bar-button.hovered ? scale-bar-button.absolute-position.x + scale-bar-button.width / 2 : dataset-export-button.hovered ? dataset-export-button.absolute-position.x + dataset-export-button.width / 2 : root.plugin-hovered-tooltip-text != "" ? root.plugin-hovered-tooltip-center-x : !root.use-native-window-controls && minimize-touch.has-hover ? minimize-control.absolute-position.x + minimize-control.width / 2 : !root.use-native-window-controls && maximize-touch.has-hover ? maximize-control.absolute-position.x + maximize-control.width / 2 : !root.use-native-window-controls && close-win-touch.has-hover ? close-control.absolute-position.x + close-control.width / 2 : 0px;
    out property <length> hovered-tooltip-top-y:
        open-button.hovered ? open-button.absolute-position.y + open-button.height + 6px : plugin-undo-button.hovered ? plugin-undo-button.absolute-position.y + plugin-undo-button.height + 6px : plugin-redo-button.hovered ? plugin-redo-button.absolute-position.y + plugin-redo-button.height + 6px : minimap-button.hovered ? minimap-button.absolute-position.y + minimap-button.height + 6px : navigate-button.hovered ? navigate-button.absolute-position.y + navigate-button.height + 6px : roi-button.hovered ? roi-button.absolute-position.y + roi-button.height + 6px : measure-button.hovered ? measure-button.absolute-position.y + measure-button.height + 6px : cpu-button.hovered ? cpu-button.absolute-position.y + cpu-button.height + 6px : gpu-button.hovered ? gpu-button.absolute-position.y + gpu-button.height + 6px : metadata-button.hovered ? metadata-button.absolute-position.y + metadata-button.height + 6px : scale-bar-button.hovered ? scale-bar-button.absolute-position.y + scale-bar-button.height + 6px : dataset-export-button.hovered ? dataset-export-button.absolute-position.y + dataset-export-button.height + 6px : root.plugin-hovered-tooltip-text != "" ? root.plugin-hovered-tooltip-top-y : !root.use-native-window-controls && minimize-touch.has-hover ? minimize-control.absolute-position.y + minimize_control.height + 6px : !root.use-native-window-controls && maximize-touch.has-hover ? maximize_control.absolute-position.y + maximize_control.height + 6px : !root.use-native-window-controls && close-win-touch.has-hover ? close-control.absolute-position.y + close_control.height + 6px : 0px;

    height: 40px;
    background: Theme.toolbar-bg;
    border-width: 0px;

    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: Theme.border-subtle;
    }

    HorizontalLayout {
        spacing: 0px;

        HorizontalLayout {
            padding: 6px;
            spacing: 4px;
            horizontal-stretch: 1;

            Rectangle {
                visible: root.use-native-window-controls;
                width: root.use-native-window-controls ? 74px : 0px;
            }

            action-cluster := HorizontalLayout {
                spacing: 4px;

                open-button := OpenFileToolButton {
                    tooltip-text: "Open file (right-click for recent)";
                    clicked => {
                        root.open-file-requested();
                    }
                    secondary-clicked(x, y) => {
                        root.open-recent-menu-requested(x, y);
                    }
                }

                plugin-undo-button := SvgToolButton {
                    visible: root.plugin-undo-redo-visible;
                    icon-source: @image-url("icons/undo.svg");
                    tooltip-text: root.undo-tooltip-text;
                    enabled: root.plugin-undo-enabled;
                    clicked => {
                        root.plugin-undo-requested(root.plugin-undo-redo-plugin-id);
                    }
                }

                plugin-redo-button := SvgToolButton {
                    visible: root.plugin-undo-redo-visible;
                    icon-source: @image-url("icons/redo.svg");
                    tooltip-text: root.redo-tooltip-text;
                    enabled: root.plugin-redo-enabled;
                    clicked => {
                        root.plugin-redo-requested(root.plugin-undo-redo-plugin-id);
                    }
                }

                minimap-button := MinimapToolButton {
                    tooltip-text: "Toggle minimap";
                    is-active: root.show-minimap;
                    clicked => {
                        root.toggle-minimap-requested();
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.border;
                    }
                }

                navigate-button := SvgToolButton {
                    icon-source: @image-url("icons/navigate.svg");
                    tooltip-text: "Navigate (Pan)";
                    is-active: root.current-tool == ToolType.navigate;
                    clicked => {
                        root.tool-selected(ToolType.navigate);
                    }
                }

                roi-button := RoiToolButton {
                    tooltip-text: "Region of interest";
                    is-active: root.current-tool == ToolType.region-of-interest;
                    clicked => {
                        root.tool-selected(ToolType.region-of-interest);
                    }
                }

                measure-button := SvgToolButton {
                    icon-source: @image-url("icons/measure.svg");
                    tooltip-text: "Measure distance";
                    is-active: root.current-tool == ToolType.measure-distance;
                    clicked => {
                        root.tool-selected(ToolType.measure-distance);
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.border;
                    }
                }

                cpu-button := ToolButton {
                    width: 40px;
                    icon: "CPU";
                    tooltip-text: "Use CPU renderer";
                    is-active: root.render-mode == RenderMode.cpu;
                    clicked => {
                        root.render-backend-selected(RenderMode.cpu);
                    }
                }

                gpu-button := ToolButton {
                    width: 40px;
                    icon: "GPU";
                    tooltip-text: root.gpu-rendering-available ? "Use GPU renderer" : "GPU renderer unavailable";
                    enabled: root.gpu-rendering-available;
                    is-active: root.render-mode == RenderMode.gpu;
                    clicked => {
                        if root.gpu-rendering-available {
                            root.render-backend-selected(RenderMode.gpu);
                        }
                    }
                }

                metadata-button := MetadataToolButton {
                    tooltip-text: "Toggle metadata HUD";
                    is-active: root.show-metadata;
                    clicked => {
                        root.toggle-metadata-requested();
                    }
                }

                scale-bar-button := SvgToolButton {
                    icon-source: @image-url("icons/toggle-measure.svg");
                    tooltip-text: "Toggle scale bar";
                    is-active: root.show-scale-bar;
                    clicked => {
                        root.toggle-scale-bar-requested();
                    }
                }

                dataset-export-button := SvgToolButton {
                    icon-source: @image-url("icons/dataset.svg");
                    tooltip-text: "Export Dataset";
                    clicked => {
                        root.dataset-export-requested();
                    }
                }

                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.border;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    filter-combo-area := Rectangle {
                        width: 82px;
                        height: 26px;
                        border-radius: 3px;
                        background: filter-combo-touch.has-hover ? Theme.surface-hover : Theme.surface;
                        border-width: 1px;
                        border-color: root.filter-popup-visible ? Theme.accent : Theme.border;

                        filter-combo-touch := TouchArea {
                            clicked => {
                                root.filter-popup-visible = !root.filter-popup-visible;
                            }
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 6px;
                            spacing: 4px;

                            Text {
                                text: root.filtering-mode == FilteringMode.bilinear ? "Bilinear" : root.filtering-mode == FilteringMode.trilinear ? "Trilinear" : "Lanczos-3";
                                color: Theme.text-primary;
                                font-size: 11px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }

                            Text {
                                text: "▾";
                                color: Theme.text-secondary;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            for btn[idx] in root.plugin-buttons: SvgToolButton {
                width: 32px;
                icon-source: btn.icon;
                tooltip-text: btn.tooltip;
                is-active: btn.active;
                changed hovered => {
                    if self.hovered {
                        root.plugin-hovered-tooltip-text = btn.tooltip;
                        root.plugin-hovered-tooltip-center-x = self.absolute-position.x + self.width / 2;
                        root.plugin-hovered-tooltip-top-y = self.absolute-position.y + self.height + 6px;
                    } else if root.plugin-hovered-tooltip-text == btn.tooltip {
                        root.plugin-hovered-tooltip-text = "";
                        root.plugin-hovered-tooltip-center-x = 0px;
                        root.plugin-hovered-tooltip-top-y = 0px;
                    }
                }
                clicked => {
                    root.plugin-button-clicked(btn.plugin-id, btn.action-id);
                }
            }

            drag-area := Rectangle {
                horizontal-stretch: 1;

                Image {
                    source: @image-url("icons/logo.png");
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    height: 20px;
                    image-fit: contain;
                }
            }
        }

        minimize-control := Rectangle {
            width: 46px;
            visible: !root.use-native-window-controls;
            background: minimize-touch.has-hover ? Theme.surface-hover : transparent;
            border-radius: 0px;

            minimize-touch := TouchArea {
                clicked => {
                    root.window-minimize();
                }
            }

            Text {
                text: "─";
                color: Theme.text-primary;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        maximize-control := Rectangle {
            width: 46px;
            visible: !root.use-native-window-controls;
            background: maximize-touch.has-hover ? Theme.surface-hover : transparent;
            border-radius: 0px;

            maximize-touch := TouchArea {
                clicked => {
                    root.window-maximize();
                }
            }

            Text {
                text: "☐";
                color: Theme.text-primary;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        close-control := Rectangle {
            width: 46px;
            visible: !root.use-native-window-controls;
            background: close-win-touch.has-hover ? #e81123 : transparent;
            border-radius: 0px;

            close-win-touch := TouchArea {
                clicked => {
                    root.window-close();
                }
            }

            Path {
                width: 10px;
                height: 10px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                stroke: close-win-touch.has-hover ? white : Theme.text-primary;
                stroke-width: 1.2px;
                commands: "M 0 0 L 10 10 M 10 0 L 0 10";
            }
        }
    }
}
