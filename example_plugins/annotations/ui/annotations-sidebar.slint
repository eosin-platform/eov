import { Theme } from "theme.slint";
import { ComboBox } from "std-widgets.slint";

export struct AnnotationTreeRow {
    row-id: string,
    parent-set-id: string,
    label: string,
    indent: int,
    is-set: bool,
    is-collapsed: bool,
    is-selected: bool,
}

component ExportIconButton inherits Rectangle {
    in property <image> icon-source;
    in property <bool> enabled: true;
    out property <bool> hovered: touch.has-hover;
    callback clicked();

    width: 32px;
    height: 28px;
    border-radius: 4px;
    background: enabled ? (touch.has-hover ? Theme.surface-hover : Theme.surface) : #ffffff08;
    border-width: 1px;
    border-color: enabled ? Theme.border : #ffffff14;

    touch := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 15px;
        height: 15px;
        source: root.icon-source;
        image-fit: contain;
        colorize: root.enabled ? Theme.text-primary : Theme.text-secondary;
    }
}

export component AnnotationsSidebar inherits Rectangle {
    in property <[string]> source-options: ["Local"];
    in property <int> source-index: 0;
    in property <[AnnotationTreeRow]> tree-items: [];
    in property <string> empty-state-text: "";
    in property <bool> can-export: false;
    in property <bool> can-delete-set: false;
    in property <string> selected-set-id: "";
    in property <string> selected-set-name: "";

    callback source-selected(string);
    callback create-set-clicked();
    callback export-clicked();
    callback delete-set-confirmed(string);
    callback delete-annotation-clicked(string);
    callback row-clicked(string);
    callback toggle-set(string);

    property <bool> context-menu-visible: false;
    property <length> context-menu-x: 0px;
    property <length> context-menu-y: 0px;
    property <string> context-target-id: "";
    property <string> context-target-name: "";
    property <bool> context-target-is-set: false;
    property <bool> delete-confirm-visible: false;
    property <string> pending-delete-set-id: "";
    property <string> pending-delete-set-name: "";

    background: Theme.surface;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-top: 10px;
        padding-right: 10px;
        padding-bottom: 10px;
        padding-left: 10px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 8px;

            Rectangle {
                horizontal-stretch: 1;
                height: 28px;
                background: transparent;

                ComboBox {
                    width: parent.width;
                    height: parent.height;
                    model: root.source-options;
                    current-index: root.source-index;
                    selected(index) => {
                        root.source-selected(index);
                    }
                }
            }

            new-set-button := ExportIconButton {
                icon-source: @image-url("icons/new_annotation_set.svg");
                clicked => {
                    root.create-set-clicked();
                }
            }

            delete-set-button := ExportIconButton {
                icon-source: @image-url("icons/delete_annotation_set.svg");
                enabled: root.can-delete-set;
                clicked => {
                    if root.can-delete-set && root.selected-set-id != "" {
                        root.pending-delete-set-id = root.selected-set-id;
                        root.pending-delete-set-name = root.selected-set-name;
                        root.delete-confirm-visible = true;
                    }
                }
            }

            export-button := ExportIconButton {
                icon-source: @image-url("icons/export.svg");
                enabled: root.can-export;
                clicked => {
                    root.export-clicked();
                }
            }
        }

        Rectangle {
            width: 100%;
            height: 1px;
            background: Theme.border;
        }

        Rectangle {
            vertical-stretch: 1;
            background: transparent;
            border-radius: 4px;
            border-width: 1px;
            border-color: Theme.border;

            if root.tree-items.length == 0: Rectangle {
                width: parent.width;
                height: parent.height;
                background: transparent;

                Text {
                    x: 14px;
                    y: 14px;
                    width: parent.width - 28px;
                    text: root.empty-state-text;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-height: tree-layout.preferred-height;
                interactive: root.tree-items.length > 0;

                tree-layout := VerticalLayout {
                    width: parent.width;
                    spacing: 0px;

                    for row[idx] in root.tree-items: Rectangle {
                        width: parent.width;
                        height: 28px;
                        background: row.is-selected ? #4da3d930 : row-touch.has-hover ? #ffffff10 : transparent;

                        row-touch := TouchArea {
                            clicked => {
                                if row.is-set {
                                    root.row-clicked(row.row-id);
                                }
                            }

                            pointer-event(e) => {
                                if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                                    root.context-target-id = row.row-id;
                                    root.context-target-name = row.label;
                                    root.context-target-is-set = row.is-set;
                                    root.context-menu-x = self.absolute-position.x + self.mouse-x - root.absolute-position.x;
                                    root.context-menu-y = self.absolute-position.y + self.mouse-y - root.absolute-position.y;
                                    root.context-menu-visible = true;
                                }
                            }
                        }

                        HorizontalLayout {
                            padding-left: (8 + row.indent * 18) * 1px;
                            padding-right: 8px;
                            spacing: 6px;

                            if row.is-set: Rectangle {
                                width: 12px;
                                height: 28px;
                                background: transparent;

                                Text {
                                    text: row.is-collapsed ? "▸" : "▾";
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    clicked => {
                                        root.toggle-set(row.row-id);
                                    }
                                }
                            }

                            if !row.is-set: Rectangle {
                                width: 12px;
                                height: 28px;
                                background: transparent;

                                Rectangle {
                                    x: 3px;
                                    y: (parent.height - self.height) / 2;
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: Theme.text-secondary;
                                }
                            }

                            Text {
                                vertical-stretch: 1;
                                text: row.label;
                                color: row.is-set ? Theme.text-primary : Theme.text-secondary;
                                font-size: row.is-set ? 12px : 11px;
                                font-weight: row.is-set ? 600 : 400;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.context-menu-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.context-menu-visible = false;
            }
        }

        Rectangle {
            x: min(root.context-menu-x, max(0px, root.width - self.width - 8px));
            y: min(root.context-menu-y, max(0px, root.height - self.height - 8px));
            width: root.context-target-is-set ? 172px : 154px;
            height: 32px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 10px;
            drop-shadow-color: #00000066;

            Rectangle {
                width: parent.width;
                height: parent.height;
                background: menu-touch.has-hover ? Theme.surface-hover : transparent;
                border-radius: 6px;

                menu-touch := TouchArea {
                    clicked => {
                        root.context-menu-visible = false;
                        if root.context-target-is-set {
                            root.pending-delete-set-id = root.context-target-id;
                            root.pending-delete-set-name = root.context-target-name;
                            root.delete-confirm-visible = true;
                        } else if root.context-target-id != "" {
                            root.delete-annotation-clicked(root.context-target-id);
                        }
                    }
                }

                Text {
                    x: 12px;
                    y: (parent.height - self.height) / 2;
                    text: root.context-target-is-set ? "Delete Annotation Set" : "Delete Annotation";
                    color: Theme.text-primary;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }
    }

    if root.delete-confirm-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #00000080;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.delete-confirm-visible = false;
            }
        }

        Rectangle {
            x: max(12px, (parent.width - self.width) / 2);
            y: max(12px, (parent.height - self.height) / 2);
            width: min(parent.width - 24px, 260px);
            height: 154px;
            background: Theme.surface;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 18px;
            drop-shadow-color: #00000088;

            VerticalLayout {
                padding-top: 14px;
                padding-right: 14px;
                padding-bottom: 14px;
                padding-left: 14px;
                spacing: 12px;

                Text {
                    text: "Delete Annotation Set";
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 700;
                }

                Text {
                    text: "Are you sure you want to delete annotation set '" + root.pending-delete-set-name + "'? This action cannot be undone.";
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                Rectangle {
                    vertical-stretch: 1;
                    background: transparent;
                }

                HorizontalLayout {
                    spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 30px;
                        border-radius: 5px;
                        background: cancel-touch.has-hover ? Theme.surface-hover : #ffffff08;
                        border-width: 1px;
                        border-color: Theme.border;

                        cancel-touch := TouchArea {
                            clicked => {
                                root.delete-confirm-visible = false;
                            }
                        }

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "Cancel";
                            color: Theme.text-primary;
                            font-size: 12px;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 30px;
                        border-radius: 5px;
                        background: delete-touch.has-hover ? #b33a3a : #982d2d;

                        delete-touch := TouchArea {
                            clicked => {
                                root.delete-confirm-visible = false;
                                if root.pending-delete-set-id != "" {
                                    root.delete-set-confirmed(root.pending-delete-set-id);
                                }
                            }
                        }

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "Delete Permanently";
                            color: #ffffff;
                            font-size: 12px;
                            font-weight: 600;
                        }
                    }
                }
            }
        }
    }
}